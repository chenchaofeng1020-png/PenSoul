        <div class="item-meta">
            <div class="meta-item"><strong>类型:</strong> Feature</div>
            <div class="meta-item"><strong>状态:</strong> completed</div>
            <div class="meta-item"><strong>优先级:</strong> high</div>
            <div class="meta-item"><strong>进度:</strong> 100%</div>
        </div>
        <div class="item-meta">
            <div class="meta-item"><strong>开始时间:</strong> 2024-01-01</div>
            <div class="meta-item"><strong>结束时间:</strong> 2024-01-15</div>
